# ─────────────────────────────────────────────────────────────────
# grok-ecw-middleware — example environment configuration.
# Copy to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# ── LLM (Grok / xAI) ─────────────────────────────────────────────
# Get your key from https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-3-mini
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# ── eClinicalWorks ───────────────────────────────────────────────
# All ECW methods are currently stubs. These values will be used
# once the client in ecw/client.py is implemented.
ECW_BASE_URL=https://your-ecw-tenant.eclinicalworks.com/mobiledoc/jsp/webemr
ECW_USERNAME=your_ecw_service_account_username
ECW_PASSWORD=your_ecw_service_account_password
ECW_CLIENT_ID=
ECW_CLIENT_SECRET=
ECW_PRACTICE_ID=
ECW_REQUEST_TIMEOUT_SECONDS=30

# ── Output Connector ─────────────────────────────────────────────
# One of: generic_server | google_drive | s3
OUTPUT_CONNECTOR=generic_server

# Used when OUTPUT_CONNECTOR=generic_server
GENERIC_SERVER_URL=https://example.com/webhook
GENERIC_SERVER_API_KEY=

# Used when OUTPUT_CONNECTOR=google_drive
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Used when OUTPUT_CONNECTOR=s3
S3_BUCKET=
S3_PREFIX=patient-records/
AWS_REGION=us-east-1
